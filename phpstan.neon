includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app

    level: 5

    excludePaths:
        - app/Filament/*

    ignoreErrors:
        -
            # Filament's HasColor interface mandates the string|array|null return type,
            # even though our match expressions only ever return a string.
            identifier: return.unusedType
            path: app/Enums/*.php
